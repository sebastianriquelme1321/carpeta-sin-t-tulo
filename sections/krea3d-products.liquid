
<section class="krea3d-section krea3d-products" id="catalogo">
  <div style="max-width:1440px;margin:0 auto;">
    <h2 class="krea3d-products__heading">{{ section.settings.heading }}</h2>
    <div class="krea3d-products__grid">
      {%- for product in section.settings.collection.products limit: section.settings.products_count -%}
        <a href="{{ product.url }}" class="krea3d-product-card">
          <div class="krea3d-product-card__image" style="background-color: {{ section.settings.card_bg }};">
            {%- if product.featured_image -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {%- else -%}
              <div style="width:60%;height:60%;display:flex;align-items:center;justify-content:center;opacity:0.35;">
                <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                  {%- for r in '0,60,120,180,240,300' | split: ',' -%}
                    <ellipse cx="50" cy="28" rx="10" ry="20" fill="{{ section.settings.icon_color }}" opacity="0.7"
                      transform="rotate({{ r }} 50 50)" />
                  {%- endfor -%}
                  <circle cx="50" cy="50" r="13" fill="{{ section.settings.icon_color }}" />
                </svg>
              </div>
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <div class="krea3d-product-card__badge">SALE</div>
            {%- endif -%}
          </div>
          <div class="krea3d-product-card__info">
            <span class="krea3d-product-card__name">{{ product.title }}</span>
            <div class="krea3d-product-card__bottom">
              <span class="krea3d-product-card__price">
                {%- if product.compare_at_price > product.price -%}
                  <s>{{ product.compare_at_price | money }}</s>
                {%- endif -%}
                {{ product.price | money }}
              </span>
              <span class="krea3d-product-card__buy">
                {%- if product.available -%}COMPRAR{%- else -%}AGOTADO{%- endif -%}
              </span>
            </div>
          </div>
        </a>
      {%- else -%}
        {%- comment -%}Fallback: sample cards when no collection assigned{%- endcomment -%}
        {%- assign sample_names = "Flores Decorativas,Macetero Diseñado,Figura Pokémon,Lámpara 3D,Pantalla de Luz,Pedido Personalizado" | split: "," -%}
        {%- assign sample_prices = "$15.000,$22.000,$18.000,$45.000,$35.000,Desde $30.000" | split: "," -%}
        {%- for i in (1..6) -%}
          {%- assign idx = forloop.index0 -%}
          <div class="krea3d-product-card">
            <div class="krea3d-product-card__image" style="background-color:{{ section.settings.card_bg }};">
              <div style="width:52%;height:52%;opacity:0.5;">
                <svg viewBox="0 0 100 100" fill="none">
                  {%- for r in '0,60,120,180,240,300' | split: ',' -%}
                    <ellipse cx="50" cy="28" rx="10" ry="20" fill="{{ section.settings.icon_color }}" opacity="0.7"
                      transform="rotate({{ r }} 50 50)" />
                  {%- endfor -%}
                  <circle cx="50" cy="50" r="13" fill="{{ section.settings.icon_color }}" />
                </svg>
              </div>
            </div>
            <div class="krea3d-product-card__info">
              <span class="krea3d-product-card__name">{{ sample_names[idx] }}</span>
              <div class="krea3d-product-card__bottom">
                <span class="krea3d-product-card__price">{{ sample_prices[idx] }}</span>
                <span class="krea3d-product-card__buy">COMPRAR</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
    {%- if section.settings.show_all_link and section.settings.collection != blank -%}
      <div style="text-align:center;padding-bottom:40px;">
        <a href="{{ section.settings.collection.url }}" class="krea3d-btn-primary" style="display:inline-block;">
          {{ section.settings.all_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Krea3D — Productos",
  "tag": "section",
  "class": "krea3d-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título de sección",
      "default": "Más vendidos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección de productos"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Número de productos"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Color de fondo de tarjetas",
      "default": "#e8f0e4"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Color del ícono placeholder",
      "default": "#8fbf8a"
    },
    {
      "type": "checkbox",
      "id": "show_all_link",
      "label": "Mostrar link 'Ver todo'",
      "default": true
    },
    {
      "type": "text",
      "id": "all_label",
      "label": "Texto del link 'Ver todo'",
      "default": "Ver toda la colección →"
    }
  ],
  "presets": [
    {
      "name": "Krea3D — Productos"
    }
  ]
}
{% endschema %}
