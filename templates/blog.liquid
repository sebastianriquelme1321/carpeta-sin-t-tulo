{{ 'krea3d.css' | asset_url | stylesheet_tag }}

<div style="max-width:1100px;margin:0 auto;padding:72px clamp(20px,4vw,40px);font-family:'Nunito',sans-serif;">
  <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(32px,4vw,52px);font-weight:300;color:#2a2220;text-align:center;margin-bottom:48px;">
    {{ blog.title }}
  </h1>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:28px;">
    {%- for article in blog.articles -%}
      <a href="{{ article.url }}" style="text-decoration:none;background:white;border-radius:12px;border:1px solid #e8ddd8;overflow:hidden;display:flex;flex-direction:column;transition:box-shadow .25s;" onmouseover="this.style.boxShadow='0 8px 32px rgba(212,132,154,.15)'" onmouseout="this.style.boxShadow='none'">
        {%- if article.image -%}
          <img src="{{ article.image | image_url: width: 640 }}" alt="{{ article.image.alt | escape }}"
            style="width:100%;aspect-ratio:16/9;object-fit:cover;" loading="lazy">
        {%- else -%}
          <div style="aspect-ratio:16/9;background:linear-gradient(135deg,#fce8ee,#e8f0e4);display:flex;align-items:center;justify-content:center;font-size:48px;">🌸</div>
        {%- endif -%}
        <div style="padding:24px;">
          <p style="font-size:11px;font-weight:800;color:#d4849a;letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px;">
            {{ article.published_at | date: '%d %b %Y' }}
          </p>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:400;color:#2a2220;margin:0 0 10px;line-height:1.2;">
            {{ article.title }}
          </h2>
          <p style="font-size:14px;color:#8a7068;line-height:1.7;margin:0;">
            {{ article.excerpt_or_content | strip_html | truncate: 120 }}
          </p>
        </div>
      </a>
    {%- endfor -%}
  </div>

  {%- if paginate.pages > 1 -%}
    <div style="display:flex;justify-content:center;gap:8px;margin-top:48px;">
      {%- if paginate.previous -%}
        <a href="{{ paginate.previous.url }}" class="krea3d-btn-primary" style="padding:10px 20px;">← Anterior</a>
      {%- endif -%}
      {%- if paginate.next -%}
        <a href="{{ paginate.next.url }}" class="krea3d-btn-primary" style="padding:10px 20px;">Siguiente →</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>
