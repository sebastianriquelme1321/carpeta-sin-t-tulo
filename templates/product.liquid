{{ 'krea3d.css' | asset_url | stylesheet_tag }}

<div style="max-width:1100px;margin:0 auto;padding:60px clamp(20px,4vw,40px);font-family:'Nunito',sans-serif;">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,5vw,80px);align-items:start;">

    <div style="border-radius:12px;overflow:hidden;background:#f5ede8;">
      {%- if product.featured_image -%}
        <img src="{{ product.featured_image | image_url: width: 900 }}"
          alt="{{ product.featured_image.alt | escape }}"
          style="width:100%;display:block;" loading="lazy">
      {%- else -%}
        <div style="aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:80px;">🌸</div>
      {%- endif -%}
    </div>

    <div>
      <p style="color:#d4849a;font-size:12px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px;">
        {{ product.type }}
      </p>
      <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3.5vw,44px);font-weight:400;color:#2a2220;margin:0 0 16px;">
        {{ product.title }}
      </h1>
      <p style="font-size:24px;font-weight:700;color:#2a2220;margin-bottom:24px;">
        {{ product.price | money }}
      </p>
      <div style="color:#5e4f46;font-size:15px;line-height:1.8;margin-bottom:32px;">
        {{ product.description }}
      </div>

      {%- form 'product', product -%}
        {%- if product.variants.size > 1 -%}
          <select name="id" style="width:100%;padding:12px 16px;border:1.5px solid #e8ddd8;border-radius:10px;background:#faf6f1;font-family:'Nunito',sans-serif;font-size:14px;margin-bottom:16px;">
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                {{ variant.title }} — {{ variant.price | money }}
              </option>
            {%- endfor -%}
          </select>
        {%- else -%}
          <input type="hidden" name="id" value="{{ product.variants.first.id }}">
        {%- endif -%}

        <button type="submit" {% unless product.available %}disabled{% endunless %}
          style="width:100%;padding:15px;background:#d4849a;color:white;border:none;border-radius:12px;font-family:'Nunito',sans-serif;font-weight:700;font-size:15px;cursor:pointer;transition:opacity .2s;"
          onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
          {%- if product.available -%}Agregar al carrito{%- else -%}Agotado{%- endif -%}
        </button>
      {%- endform -%}
    </div>
  </div>
</div>
