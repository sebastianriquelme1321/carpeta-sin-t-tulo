{{ 'krea3d.css' | asset_url | stylesheet_tag }}

<div style="max-width:1440px;margin:0 auto;padding:72px clamp(20px,3vw,44px);">
  <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(32px,4vw,52px);font-weight:300;color:#2a2220;text-align:center;margin-bottom:48px;">
    {{ collection.title }}
  </h1>

  <div class="krea3d-products__grid">
    {%- for product in collection.products -%}
      <a href="{{ product.url }}" class="krea3d-product-card">
        <div class="krea3d-product-card__image" style="background:#e8f0e4;">
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 600 }}"
              alt="{{ product.featured_image.alt | escape }}"
              loading="lazy" width="600" height="600">
          {%- else -%}
            <div style="font-size:56px;opacity:.4;">🌸</div>
          {%- endif -%}
          {%- if product.compare_at_price > product.price -%}
            <div class="krea3d-product-card__badge">SALE</div>
          {%- endif -%}
        </div>
        <div class="krea3d-product-card__info">
          <span class="krea3d-product-card__name">{{ product.title }}</span>
          <div class="krea3d-product-card__bottom">
            <span class="krea3d-product-card__price">{{ product.price | money }}</span>
            <span class="krea3d-product-card__buy">
              {%- if product.available -%}COMPRAR{%- else -%}AGOTADO{%- endif -%}
            </span>
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>
