{{ 'krea3d.css' | asset_url | stylesheet_tag }}

<div style="max-width:860px;margin:0 auto;padding:72px clamp(20px,4vw,40px);font-family:'Nunito',sans-serif;">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:40px;flex-wrap:wrap;gap:16px;">
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3.5vw,44px);font-weight:300;color:#2a2220;margin:0;">
      Hola, {{ customer.first_name }}
    </h1>
    <a href="{{ routes.account_logout_url }}" style="font-size:13px;color:#8a7068;text-decoration:none;border:1px solid #e8ddd8;padding:8px 18px;border-radius:8px;">
      Cerrar sesión
    </a>
  </div>

  <h2 style="font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:#2a2220;margin-bottom:20px;">
    Pedidos recientes
  </h2>

  {%- if customer.orders.size == 0 -%}
    <div style="background:white;border-radius:12px;border:1px solid #e8ddd8;padding:40px;text-align:center;">
      <p style="font-size:48px;margin-bottom:12px;">🌸</p>
      <p style="color:#8a7068;font-size:15px;margin-bottom:24px;">Aún no tienes pedidos.</p>
      <a href="{{ routes.all_products_collection_url }}" class="krea3d-btn-primary">Ver catálogo</a>
    </div>
  {%- else -%}
    <div style="background:white;border-radius:12px;border:1px solid #e8ddd8;overflow:hidden;">
      {%- for order in customer.orders -%}
        <div style="padding:20px 24px;border-bottom:1px solid #e8ddd8;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;">
          <div>
            <a href="{{ order.customer_url }}" style="font-weight:700;color:#2a2220;text-decoration:none;font-size:15px;">
              Pedido {{ order.name }}
            </a>
            <p style="font-size:13px;color:#8a7068;margin:4px 0 0;">{{ order.created_at | date: '%d %b %Y' }}</p>
          </div>
          <div style="text-align:right;">
            <p style="font-weight:700;color:#d4849a;margin:0;">{{ order.total_price | money }}</p>
            <p style="font-size:12px;font-weight:700;color:#8a7068;margin:4px 0 0;text-transform:uppercase;letter-spacing:.06em;">{{ order.financial_status_label }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
