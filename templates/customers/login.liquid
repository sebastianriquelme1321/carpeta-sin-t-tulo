{{ 'krea3d.css' | asset_url | stylesheet_tag }}

<div style="max-width:480px;margin:0 auto;padding:72px clamp(20px,4vw,40px);font-family:'Nunito',sans-serif;">
  <h1 style="font-family:'Cormorant Garamond',serif;font-size:40px;font-weight:300;color:#2a2220;text-align:center;margin-bottom:8px;">
    Iniciar sesión
  </h1>
  <p style="text-align:center;color:#8a7068;font-size:14px;margin-bottom:36px;">
    ¿No tienes cuenta? <a href="{{ routes.account_register_url }}" style="color:#d4849a;font-weight:700;">Regístrate</a>
  </p>

  {%- form 'customer_login' -%}
    {%- if form.errors -%}
      <div style="background:rgba(212,132,154,.1);border:1px solid rgba(212,132,154,.25);border-radius:10px;padding:14px 18px;margin-bottom:20px;color:#8a4058;font-size:14px;">
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    <div style="background:white;border-radius:12px;border:1px solid #e8ddd8;padding:32px;">
      <div style="margin-bottom:18px;">
        <label style="display:block;font-size:13px;font-weight:700;color:#2a2220;margin-bottom:6px;">Email</label>
        <input type="email" name="customer[email]" autocomplete="email" required
          style="width:100%;padding:12px 16px;border:1.5px solid #e8ddd8;border-radius:10px;background:#faf6f1;font-family:'Nunito',sans-serif;font-size:14px;color:#2a2220;box-sizing:border-box;outline:none;"
          onfocus="this.style.borderColor='#d4849a'" onblur="this.style.borderColor='#e8ddd8'">
      </div>
      <div style="margin-bottom:24px;">
        <label style="display:block;font-size:13px;font-weight:700;color:#2a2220;margin-bottom:6px;">Contraseña</label>
        <input type="password" name="customer[password]" autocomplete="current-password" required
          style="width:100%;padding:12px 16px;border:1.5px solid #e8ddd8;border-radius:10px;background:#faf6f1;font-family:'Nunito',sans-serif;font-size:14px;color:#2a2220;box-sizing:border-box;outline:none;"
          onfocus="this.style.borderColor='#d4849a'" onblur="this.style.borderColor='#e8ddd8'">
      </div>
      <button type="submit" class="krea3d-btn-primary" style="width:100%;padding:15px;font-size:15px;">
        Iniciar sesión
      </button>
      <p style="text-align:center;margin-top:16px;">
        <a href="{{ routes.account_recover_url }}" style="font-size:13px;color:#8a7068;text-decoration:none;">¿Olvidaste tu contraseña?</a>
      </p>
    </div>
  {%- endform -%}
</div>
